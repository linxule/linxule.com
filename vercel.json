{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Link",
          "value": "</llms.txt>; rel=\"llms-txt\", </llms.txt>; rel=\"describedby\"; type=\"text/plain\", </sitemap.xml>; rel=\"sitemap\"; type=\"application/xml\", </feed.xml>; rel=\"alternate\"; type=\"application/atom+xml\"; title=\"Atom feed\", </site-index.json>; rel=\"index\"; type=\"application/json\", </.well-known/api-catalog>; rel=\"api-catalog\"; type=\"application/linkset+json\""
        }
      ]
    },
    {
      "source": "/:path*.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/.well-known/api-catalog",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/linkset+json; charset=utf-8"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/writing/attachments/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/((?!_vercel|api|cdn-cgi).*)",
      "has": [
        {
          "type": "header",
          "key": "Accept",
          "value": ".*text/html.*"
        }
      ],
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=60, stale-while-revalidate=600"
        },
        {
          "key": "Vary",
          "value": "Accept"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/favicon.ico",
      "destination": "/assets/favicon.svg",
      "statusCode": 301
    },
    {
      "source": "/favicon.png",
      "destination": "/assets/favicon-32.png",
      "statusCode": 301
    },
    {
      "source": "/curation-dao/:path*",
      "destination": "/writing/dao-governance-resources",
      "statusCode": 301
    },
    {
      "source": "/curation-dao",
      "destination": "/writing/dao-governance-resources",
      "statusCode": 301
    },
    {
      "source": "/daogov/:path*",
