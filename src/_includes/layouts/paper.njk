---
layout: layouts/base.njk
marker: "papers"
---
<style>
    .paper { max-width: var(--measure, 38rem); margin: 10rem auto 6rem; padding: 0 2rem; }
    .paper-venue { font-family: "IBM Plex Mono", monospace; font-size: .78rem; letter-spacing: .05em; text-transform: uppercase; opacity: .65; }
    .paper h1 { font-size: 1.9rem; line-height: 1.22; margin: .6rem 0 1rem; }
    .paper-authors { font-style: italic; font-size: 1.05rem; margin-bottom: .4rem; }
    .paper-meta { font-size: .9rem; opacity: .8; margin-bottom: 1.5rem; }
    .paper-meta a { text-decoration: none; border-bottom: 1px solid currentColor; }
    .paper-pdf { font-family: "IBM Plex Mono", monospace; font-size: .9rem; margin: 1.5rem 0; }
    .paper-abstract { margin: 2rem 0; }
    .paper-abstract h2 { font-size: .82rem; font-family: "IBM Plex Mono", monospace; letter-spacing: .05em; text-transform: uppercase; opacity: .65; margin-bottom: .5rem; }
    .paper-links { display: flex; flex-wrap: wrap; gap: 1.2rem; margin: 2rem 0; font-family: "IBM Plex Mono", monospace; font-size: .85rem; }
    .paper-cite { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,.12); font-size: .85rem; }
    .paper-cite .label { font-family: "IBM Plex Mono", monospace; letter-spacing: .05em; text-transform: uppercase; opacity: .65; }
    .paper-cite code { display: block; white-space: pre-wrap; background: rgba(0,0,0,.035); padding: 1rem; border-radius: 2px; margin-top: .6rem; font-family: "IBM Plex Mono", monospace; font-size: .8rem; line-height: 1.5; }
    .paper-license { margin-top: 1.5rem; font-size: .8rem; opacity: .7; }
</style>
<article class="paper">
    <div class="paper-venue">{{ venue }}{% if venueType == 'journal' %} · Article{% elif venueType == 'preprint' %} · Preprint{% endif %}{% if year %} · {{ year }}{% endif %}</div>
    <h1>{{ paperTitle | default(title) }}</h1>
    <div class="paper-authors">{% for a in authors %}{{ a.name }}{% if not loop.last %}, {% endif %}{% endfor %}</div>
    <div class="paper-meta">
        {%- if venue %}{{ venue }}{% if year %} ({{ year }}){% endif %}.{% endif %}
        {%- if doi %} DOI: <a href="https://doi.org/{{ doi }}">{{ doi }}</a>.{% endif %}
        {%- if arxivId %} arXiv: <a href="https://arxiv.org/abs/{{ arxivId }}">{{ arxivId }}</a>.{% endif %}
        {%- if license %} <a href="{{ license }}" rel="license">CC BY 4.0</a>.{% endif %}
    </div>

    {% if pdf %}
    <p class="paper-pdf"><a href="{{ page.url }}{{ pdf }}">↓ Download PDF (full text)</a></p>
    {% endif %}

    {% if abstract %}
    <div class="paper-abstract">
        <h2>Abstract</h2>
        <p>{{ abstract }}</p>
    </div>
    {% endif %}

    {% if links %}
    <nav class="paper-links">
        {% for l in links %}<a href="{{ l.href }}">{{ l.label }}</a>{% endfor %}
    </nav>
    {% endif %}

    {{ content | safe }}

    <div class="paper-cite">
        <span class="label">Cite</span>
        <code>{% for a in authors %}{{ a.name }}{% if not loop.last %}, {% endif %}{% endfor %} ({{ year }}). {{ paperTitle | default(title) }}. {% if venue %}{{ venue }}. {% endif %}{% if doi %}https://doi.org/{{ doi }}{% elif arxivId %}arXiv:{{ arxivId }}{% endif %}</code>
    </div>

    {% if license %}
    <link rel="license" href="{{ license }}">
    <p class="paper-license">Licensed under <a href="{{ license }}" rel="license">CC BY 4.0</a> — reuse and build on it, with attribution.</p>
    {% endif %}
</article>
