<!DOCTYPE html>
<html lang="{{ lang | default(site.language) | default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if seoTitle %}{{ seoTitle }} · {{ site.title }}{% elif title %}{{ title }} · {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>

    {# Meta Description - seoDescription override, then per-page description, then portrait/artifact fallbacks #}
    {%- set metaDescription = seoDescription or description -%}
    {%- if not metaDescription and layout == 'layouts/portrait.njk' -%}
      {%- if images and images[0] and images[0].alt -%}
        {%- set metaDescription = images[0].alt -%}
      {%- elif prompt and prompt[0] -%}
        {%- set metaDescription = prompt[0].text | default(prompt[0]) -%}
      {%- endif -%}
    {%- endif -%}
    {%- if not metaDescription and layout == 'layouts/artifact.njk' -%}
      {%- if contextExcerpt and contextExcerpt[0] -%}
        {%- set metaDescription = contextExcerpt[0].text | default(contextExcerpt[0]) -%}
      {%- endif -%}
    {%- endif -%}
    {%- if not metaDescription and layout == 'layouts/talk.njk' -%}
      {%- if event -%}
        {%- set metaDescription = title ~ ' — presented at ' ~ event ~ '.' -%}
      {%- else -%}
        {%- set metaDescription = title ~ ' — a ' ~ (type | default('talk')) ~ ' by ' ~ site.author ~ '.' -%}
      {%- endif -%}
    {%- endif -%}
    <meta name="description" content="{{ metaDescription | default(site.description) | truncate(147) }}">
    {%- if robots %}
    <meta name="robots" content="{{ robots }}">
    {%- endif %}
    <meta name="baidu-site-verification" content="codeva-4hCK3zYdYU">
    <meta name="author" content="{{ site.authorZh | default('') }} ({{ site.author }})">

    {# Baidu uses content-language meta instead of hreflang #}
    {%- if lang and lang.startsWith('zh') %}
    <meta http-equiv="content-language" content="zh-Hans">
    {%- endif %}

    {# hreflang for Google: link English/Chinese CV variants #}
    {%- if page.url == '/cv/' or page.url == '/cv-zh/' %}
    <link rel="alternate" hreflang="en" href="{{ site.url }}/cv">
    <link rel="alternate" hreflang="zh" href="{{ site.url }}/cv-zh">
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}/cv">
    {%- endif %}

    {# Canonical URL — strip trailing slash to match vercel.json trailingSlash: false #}
    <link rel="canonical" href="{{ site.url }}{{ page.url | replace(r/\/$/, '') }}">

    {# Open Graph #}
    {# Smart OG image: explicit ogImage > first image from images[] > src field > default #}
    {%- set ogImg = ogImage -%}
    {%- if not ogImg and images and images[0] and images[0].src and not (images[0].src | isHTMLFile) -%}
      {%- set ogImg = images[0].src -%}
    {%- endif -%}
    {%- if not ogImg and src and not (src | isHTMLFile) -%}
      {%- set ogImg = src -%}
    {%- endif -%}
    {# Downscale the resolved hero to a small social card — never serve a raw multi-MB source as og:image. See .claude/rules/og-images.md #}
    {%- set ogImg = ogImg | ogCard -%}
    {# No hero image: image-less content pages (writing w/o cover, HTML artifacts) get a generated title card; everything else gets the brand/default card. #}
    {%- if not ogImg -%}
      {%- set auto = page.fileSlug | autoCardPath(layout) -%}
      {%- if auto -%}{%- set ogImg = auto -%}{%- endif -%}
    {%- endif -%}
    {%- if not ogImg -%}{%- set ogImg = '/assets/og-cards/default.jpg' -%}{%- endif -%}
    <meta property="og:title" content="{% if seoTitle %}{{ seoTitle }} · {% elif title %}{{ title }} · {% endif %}{{ site.title }}">
    <meta property="og:description" content="{{ metaDescription | default(site.description) | truncate(147) }}">
    <meta property="og:type" content="{% if layout == 'layouts/writing.njk' %}article{% else %}website{% endif %}">
    <meta property="og:url" content="{{ site.url }}{{ page.url | replace(r/\/$/, '') }}">
    <meta property="og:image" content="{{ site.url }}{{ ogImg }}">
    {%- if not ogImg.endsWith('.svg') %}
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/{% if ogImg.endsWith('.png') %}png{% else %}jpeg{% endif %}">
    {%- endif %}
    <meta property="og:image:alt" content="{{ (metaDescription or title or site.description) | truncate(200) }}">
    <meta property="og:site_name" content="{{ site.title }}">

    {# Twitter Card #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@linxule">
    <meta name="twitter:creator" content="@linxule">
    <meta name="twitter:title" content="{% if seoTitle %}{{ seoTitle }} · {% elif title %}{{ title }} · {% endif %}{{ site.title }}">
    <meta name="twitter:description" content="{{ metaDescription | default(site.description) | truncate(147) }}">
    <meta name="twitter:image" content="{{ site.url }}{{ ogImg }}">
    <meta name="twitter:image:alt" content="{{ (metaDescription or title or site.description) | truncate(200) }}">

    {# Favicon #}
    <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/assets/favicon-32.png" sizes="32x32" type="image/png">
    <link rel="icon" href="/assets/favicon-192.png" sizes="192x192" type="image/png">
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">

    {# FOUC cloak — hide body until web fonts are ready (with 1.5s fallback timer
       so the page never stays hidden if a font request hangs). Inline because
       it must run before the body paints. JS-disabled clients skip the cloak. #}
    <style>html.fonts-loading body{visibility:hidden}</style>
    <script>
    (function(){
        var h=document.documentElement;
        h.classList.add('fonts-loading');
        function reveal(){h.classList.remove('fonts-loading');}
        var fb=setTimeout(reveal,1500);
        if(document.fonts&&document.fonts.ready){
            document.fonts.ready.then(function(){clearTimeout(fb);reveal();});
        }
    })();
    </script>

    {# Fonts - loaded as <link> not @import to start download early #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=IBM+Plex+Mono:wght@300;400&family=Noto+Serif+SC:wght@300;400;500&display=swap">

    <link rel="alternate" type="application/atom+xml" title="{{ site.title }} - Writing" href="/feed.xml">
    <link rel="stylesheet" href="/assets/css/main.css?v={{ site.version }}">

    {# LLMs.txt for AI assistants - emerging standard for machine-readable site context #}
    <link rel="llms-txt" href="/llms.txt" type="text/plain">
    <meta name="llms-txt" content="/llms.txt">

    {# RSL 1.0 machine-readable license (Really Simple Licensing) — free use incl. AI training, attribution required (CC BY 4.0) #}
    <link rel="license" type="application/rsl+xml" href="/license.xml">

    {# rel=me identity backlinks (IndieAuth / social-graph reconciliation) #}
    <link rel="me" href="https://research-memex.org">
    <link rel="me" href="https://github.com/linxule">
    <link rel="me" href="https://x.com/linxule">
    <link rel="me" href="https://orcid.org/0000-0001-7885-4194">

    {# Markdown twin — ONE computation drives both the head alternate and the footer
       rendering marker, so the marker can never claim a twin that doesn't exist.
       Series landings (/writing/series/*) are deliberately excluded: curated HTML
       surfaces whose essays already twin (design-system.md § Renderings). #}
    {%- set mdAlternate = '' %}
    {%- if page.url and (page.url.startsWith('/writing/') or page.url.startsWith('/making/portraits/') or page.url.startsWith('/making/artifacts/') or page.url.startsWith('/talks/') or page.url.startsWith('/papers/')) and not page.url.startsWith('/writing/series/') and page.url != '/writing/' and page.url != '/talks/' and page.url != '/making/portraits/' and page.url != '/making/artifacts/' and page.url != '/papers/' %}
    {%- set mdAlternate = page.url | replace(r/\/$/, "") + ".md" %}
    {%- endif %}
    {%- if page.url == '/writing/' or page.url == '/talks/' or page.url == '/making/' or page.url == '/papers/' or page.url == '/cv/' or page.url == '/cv-zh/' or page.url == '/thinking/' or page.url == '/teaching/' or page.url == '/concepts/' %}
    {%- set mdAlternate = page.url | replace(r/\/$/, "") + ".md" %}
    {%- endif %}
    {%- if page.url == '/' %}
    {%- set mdAlternate = '/index.md' %}
    {%- endif %}
    {%- if mdAlternate %}
    <link rel="alternate" type="text/markdown" href="{{ mdAlternate }}">
    {%- endif %}
    {%- if page.url == '/concepts/' %}
    <link rel="license" href="https://creativecommons.org/licenses/by/4.0/">
    {%- endif %}

    {# Vercel Analytics #}
    <script>
        window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>

    {# JSON-LD Structured Data #}
    {% if page.url == '/' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfilePage",
      "mainEntity": {
        "@type": "Person",
        "@id": "{{ site.url }}/#person",
        "name": "{{ site.author }}",
        "alternateName": "{{ site.authorZh }}",
        "url": "{{ site.url }}",
        "description": "{{ site.description }}",
        "jobTitle": "PhD Researcher",
        "email": "x@linxule.com",
        "affiliation": [
          {
            "@type": "Organization",
            "name": "Imperial College London",
            "alternateName": "帝国理工学院"
          },
          {
            "@type": "Organization",
            "name": "SKEMA Business School",
            "alternateName": "SKEMA商学院"
          }
        ],
        "hasOccupation": [
          {"@type": "Occupation", "name": "PhD Researcher"},
          {"@type": "Occupation", "name": "Assistant Professor"}
        ],
        "worksFor": {
          "@type": "OrganizationRole",
          "roleName": "Assistant Professor",
          "startDate": "2026-08",
          "worksFor": {"@type": "Organization", "name": "SKEMA Business School", "alternateName": "SKEMA商学院"}
        },
        "alumniOf": {"@type": "CollegeOrUniversity", "name": "Imperial College London", "alternateName": "帝国理工学院"},
        "knowsAbout": ["Human-AI collaboration", "AI integration in organizations", "Organizational design", "AI governance", "Qualitative research methods", "Grounded theory", "Polanyi Inversion", "Interpretive Orchestration", "Cognitive Signatures", "Completion Authority", "Token Duality", "人机协作", "组织设计", "AI治理", "后AGI组织", "去中心化治理", "定性研究方法", "扎根理论", "波兰尼反转", "诠释性编排", "认知签名", "完成裁定权", "代币二元性"],
        "knowsLanguage": ["en", "zh"],
        "identifier": {
          "@type": "PropertyValue",
          "propertyID": "ORCID",
          "value": "0000-0001-7885-4194"
        },
        "sameAs": [
          "https://scholar.google.com/citations?user=ryocLTAAAAAJ",
          "https://www.semanticscholar.org/author/Xule-Lin/2157775311",
          "https://www.aminer.cn/profile/69b6d6376ac83d07433409d3",
          "https://github.com/linxule",
          "https://huggingface.co/linxule",
          "https://x.com/linxule",
          "https://linkedin.com/in/linxule",
          "https://orcid.org/0000-0001-7885-4194",
          "https://profiles.imperial.ac.uk/xule.lin",
          "https://threadcounts.org",
          "https://xhslink.com/m/5411hXmoy5T",
          "https://research-memex.org/#person"
        ],
        "image": {
          "@type": "ImageObject",
          "url": "{{ site.url }}/assets/headshot.jpg",
          "width": 886,
          "height": 886,
          "caption": "{{ site.author }} {{ site.authorZh }}"
        }
      },
      "relatedLink": {
        "@type": "WebPage",
        "url": "{{ site.url }}/llms.txt",
        "name": "AI Interaction Guidelines",
        "description": "Machine-readable site context for AI assistants and language models"
      },
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "usageInfo": "{{ site.url }}/llms.txt",
      "copyrightHolder": {"@id": "{{ site.url }}/#person"}
    }
    </script>
    {% endif %}
    {% if layout == 'layouts/writing.njk' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "{{ title }}",
      "description": "{{ description | default(subtitle) | default(site.description) }}",
      "datePublished": "{{ date.toISOString().split('T')[0] }}",
      "author": [{% for author in authors %}{"@type": "Person", {% if author == site.author %}"@id": "{{ site.url }}/#person", {% endif %}"name": "{{ author }}"}{% if not loop.last %}, {% endif %}{% endfor %}],
      "publisher": {"@type": "Person", "@id": "{{ site.url }}/#person", "name": "{{ site.author }}"},
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "usageInfo": "{{ site.url }}/llms.txt",
      "copyrightHolder": {"@type": "Person", "@id": "{{ site.url }}/#person", "name": "{{ site.author }}"},
      "copyrightYear": "{{ date.getFullYear() }}",
      "mainEntityOfPage": "{{ site.url }}{{ page.url | replace(r/\/$/, '') }}"{% if defines %},
      "hasPart": [{% for def in defines %}{
        "@type": "DefinedTerm",
        "name": "{{ def.term }}",
        "description": {{ def.definition | dump | safe }},
        "url": "{{ site.url }}{{ page.url | replace(r/\/$/, '') }}#dfn-{{ def.term | slugify }}",
        "inDefinedTermSet": "{{ site.url }}/concepts/",
        "creator": {"@type": "Person", "@id": "{{ site.url }}/#person", "name": "{{ site.author }}"}
      }{% if not loop.last %}, {% endif %}{% endfor %}]{% endif %}
    }
    </script>
    {% endif %}
    {% if page.url == '/concepts/' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "DefinedTermSet",
      "@id": "{{ site.url }}/concepts/",
      "name": "Signature Concepts — {{ site.author }}",
      "url": "{{ site.url }}/concepts/",
      "inLanguage": "en",
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "usageInfo": "{{ site.url }}/llms.txt",
      "hasDefinedTerm": [{% for concept in collections.concepts %}{
        "@type": "DefinedTerm",
        "name": {{ concept.term | dump | safe }},
        "description": {{ concept.definition | dump | safe }},
        "url": "{{ site.url }}{{ concept.url | replace(r/\/$/, '') }}#{{ concept.anchor }}",
        "inDefinedTermSet": "{{ site.url }}/concepts/",
        "creator": {"@type": "Person", "@id": "{{ site.url }}/#person", "name": "{{ site.author }}"}
      }{% if not loop.last %}, {% endif %}{% endfor %}]
    }
    </script>
    {% endif %}
    {% if layout == 'layouts/portrait.njk' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ImageGallery",
      "name": "{{ title }}",
      "description": "{{ metaDescription | default(site.description) }}",
      "datePublished": "{{ date.toISOString().split('T')[0] }}",
      "creator": {"@type": "Person", "name": "{{ prompter | default(site.author) }}"},
      "publisher": {"@type": "Person", "@id": "{{ site.url }}/#person", "name": "{{ site.author }}"},
      "mainEntityOfPage": "{{ site.url }}{{ page.url | replace(r/\/$/, '') }}"{% if images %},
      "image": [{% for image in images %}"{{ site.url }}{{ image.src }}"{% if not loop.last %}, {% endif %}{% endfor %}]{% endif %}
    }
    </script>
    {% endif %}
    {% if layout == 'layouts/artifact.njk' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "CreativeWork",
      "name": "{{ title }}",
      "description": "{{ metaDescription | default(site.description) }}",
      "datePublished": "{{ date.toISOString().split('T')[0] }}",
      "creator": {"@type": "SoftwareApplication", "name": "{{ creator | default('Claude') }}"},
      "publisher": {"@type": "Person", "@id": "{{ site.url }}/#person", "name": "{{ site.author }}"},
      "mainEntityOfPage": "{{ site.url }}{{ page.url | replace(r/\/$/, '') }}"{% if src %},
      "image": "{{ site.url }}{{ src }}"{% endif %}{% if medium %},
      "artMedium": "{{ medium }}"{% endif %}
    }
    </script>
    {% endif %}

    {% if layout == 'layouts/talk.njk' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "PresentationDigitalDocument",
      "name": {{ title | dump | safe }},
      "description": {{ metaDescription | default(site.description) | dump | safe }},
      "datePublished": "{{ date.toISOString().split('T')[0] }}",
      "author": [{% if speakers %}{% for speaker in speakers %}{"@type": "Person", {% if speaker == site.author %}"@id": "{{ site.url }}/#person", {% endif %}"name": {{ speaker | dump | safe }}}{% if not loop.last %}, {% endif %}{% endfor %}{% else %}{"@type": "Person", "@id": "{{ site.url }}/#person", "name": {{ site.author | dump | safe }}}{% endif %}],
      "publisher": {"@type": "Person", "@id": "{{ site.url }}/#person", "name": {{ site.author | dump | safe }}},
      "mainEntityOfPage": "{{ site.url }}{{ page.url | replace(r/\/$/, '') }}"{% if youtube %},
      "video": {"@type": "VideoObject", "name": {{ title | dump | safe }}, "embedUrl": "https://www.youtube.com/embed/{{ youtube }}", "uploadDate": "{{ date.toISOString().split('T')[0] }}", "thumbnailUrl": "https://i.ytimg.com/vi/{{ youtube }}/hqdefault.jpg"}{% elif video %},
      "video": {"@type": "VideoObject", "name": {{ title | dump | safe }}, "embedUrl": {{ video | dump | safe }}, "uploadDate": "{{ date.toISOString().split('T')[0] }}"}{% endif %}
    }
    </script>
    {% endif %}

    {% if layout == 'layouts/paper.njk' %}
    {# Google Scholar / Highwire citation metadata — one paper = one landing-page URL.
       citation_pdf_url is emitted ONLY when a co-located `pdf:` is present (no dangling links). #}
    <meta name="citation_title" content="{{ paperTitle | default(title) }}">
    {%- for a in authors %}
    <meta name="citation_author" content="{{ a.name }}">
    {%- endfor %}
    <meta name="citation_publication_date" content="{{ pubDate }}">
    {%- if venueType == 'journal' and venue %}
    <meta name="citation_journal_title" content="{{ venue }}">
    {%- endif %}
    {%- if publisher %}
    <meta name="citation_publisher" content="{{ publisher }}">
    {%- endif %}
    {%- if doi %}
    <meta name="citation_doi" content="{{ doi }}">
    {%- endif %}
    {%- if arxivId %}
    <meta name="citation_arxiv_id" content="{{ arxivId }}">
    <meta name="citation_technical_report_institution" content="arXiv">
    {%- endif %}
    <meta name="citation_abstract_html_url" content="{{ site.url }}{{ page.url | replace(r/\/$/, '') }}">
    {%- if pdf %}
    <meta name="citation_pdf_url" content="{{ site.url }}{{ page.url }}{{ pdf }}">
    {%- endif %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ScholarlyArticle",
      "headline": {{ (paperTitle | default(title)) | dump | safe }},
      "name": {{ (paperTitle | default(title)) | dump | safe }},
      "author": [{% for a in authors %}{"@type": "Person", {% if a.self %}"@id": "{{ site.url }}/#person", {% endif %}"name": {{ a.name | dump | safe }}{% if a.orcid %}, "identifier": "https://orcid.org/{{ a.orcid }}", "sameAs": "https://orcid.org/{{ a.orcid }}"{% endif %}}{% if not loop.last %}, {% endif %}{% endfor %}],
      "datePublished": "{{ date.toISOString().split('T')[0] }}",
      "publisher": {% if publisher %}{"@type": "Organization", "name": {{ publisher | dump | safe }}}{% else %}{"@type": "Person", "@id": "{{ site.url }}/#person", "name": "{{ site.author }}"}{% endif %},
      "mainEntityOfPage": "{{ site.url }}{{ page.url | replace(r/\/$/, '') }}",
      "url": "{{ site.url }}{{ page.url | replace(r/\/$/, '') }}"{% if venueType == 'journal' and venue %},
      "isPartOf": {"@type": "Periodical", "name": {{ venue | dump | safe }}}{% endif %}{% if doi %},
      "identifier": {"@type": "PropertyValue", "propertyID": "DOI", "value": "{{ doi }}"},
      "sameAs": "https://doi.org/{{ doi }}"{% endif %}{% if license %},
      "license": "{{ license }}"{% endif %}{% if abstract %},
      "abstract": {{ abstract | striptags | dump | safe }}{% endif %},
      "creativeWorkStatus": "{{ creativeWorkStatus | default('Published') }}",
      "inLanguage": "en"
    }
    </script>
    {% endif %}

    {% block head %}{% endblock %}
</head>
<body>
    {# AI Breadcrumb - consolidated AI discoverability elements #}
    {% set isHomepage = page.url == '/' %}
    {% include "partials/ai-breadcrumb.njk" %}

    <a href="#main-content" class="sr-only">Skip to content</a>
    <div class="bloom-cursor" id="bloom"></div>

    <nav class="spine">
        <a href="/" class="spine-name">XULE LIN</a>
        {% if marker %}
        <span class="spine-marker">{{ marker }}</span>
        {% endif %}
    </nav>
    
    <main id="main-content">
        {% if seoH1 %}<h1 class="sr-only">{{ seoH1 }}</h1>{% endif %}
        {{ content | safe }}
    </main>
    
    {# The rendering marker — dormant since the initial commit, wired 2026-07-08.
       Appears exactly when the page has a markdown twin (same mdAlternate
       computation as the head's alternate link). The site's thesis as navigation. #}
    {% if mdAlternate %}
    <div class="rendering">one rendering · <a href="{{ mdAlternate }}">the source remains</a></div>
    {% endif %}
    
    <script>
        // Bloom cursor effect
        const bloom = document.getElementById('bloom');
        document.addEventListener('mousemove', (e) => {
            bloom.style.left = e.clientX + 'px';
            bloom.style.top = e.clientY + 'px';
        });

        // External links open in new tab
        document.querySelectorAll('a[href^="http"]').forEach(link => {
            if (!link.href.includes(window.location.hostname)) {
                link.setAttribute('target', '_blank');
                link.setAttribute('rel', 'noopener noreferrer');
            }
        });

        // Enable browser scroll restoration
        if ('scrollRestoration' in history) {
            history.scrollRestoration = 'auto';
        }

        // Temporarily disable smooth scroll during back/forward navigation.
        // Restore by CLEARING the inline style (never set 'smooth' inline — it would
        // override the prefers-reduced-motion CSS; the stylesheet decides).
        window.addEventListener('pageshow', (event) => {
            if (event.persisted) {
                document.documentElement.style.scrollBehavior = 'auto';
                setTimeout(() => {
                    document.documentElement.style.scrollBehavior = '';
                }, 100);
            }
        });

        // Scroll position restoration for in-page navigation
        (function() {
            const currentPath = window.location.pathname;

            // Save scroll position when clicking links to detail pages
            // (links that go deeper into the site)
            document.addEventListener('click', (e) => {
                const link = e.target.closest('a');
                if (!link) return;

                const href = link.getAttribute('href');
                if (!href || href.startsWith('#') || href.startsWith('http')) return;

                // Save current scroll position with current path
                sessionStorage.setItem('scrollPos_' + currentPath, window.scrollY);
            });

            // Check if we're returning to a page we left
            const savedPos = sessionStorage.getItem('scrollPos_' + currentPath);
            if (savedPos && document.referrer) {
                // Only restore if coming from a child page (longer path)
                try {
                    const referrerPath = new URL(document.referrer).pathname;
                    if (referrerPath.startsWith(currentPath) && referrerPath !== currentPath) {
                        document.documentElement.style.scrollBehavior = 'auto';
                        window.scrollTo(0, parseInt(savedPos));
                        sessionStorage.removeItem('scrollPos_' + currentPath);
                        setTimeout(() => {
                            document.documentElement.style.scrollBehavior = '';
                        }, 100);
                    }
                } catch (e) {
                    // Malformed referrer, skip restoration
                }
            }
        })();
    </script>

    {# Paper texture — generated per session, unique like handmade paper #}
    <script defer src="/assets/js/paper.js?v={{ site.version }}"></script>

</body>
</html>
