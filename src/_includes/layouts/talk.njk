---
layout: layouts/base.njk
marker: "talks"
---

<style>
    .talk-container {
        display: grid;
        grid-template-columns: 1fr minmax(auto, var(--measure)) 1fr;
        gap: 0 2rem;
        padding: 10rem 2rem 6rem;
    }

    .talk-content {
        grid-column: 2;
    }

    .talk-header {
        margin-bottom: 3rem;
    }

    .talk-num {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.6rem;
        color: var(--ink-ghost);
        letter-spacing: 0.2em;
        margin-bottom: 1.5rem;
    }

    .talk-title {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 300;
        line-height: 1.3;
        margin-bottom: 1rem;
    }

    .talk-meta {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        color: var(--ink-faint);
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 2rem;
        margin-bottom: 1rem;
    }

    .meta-label {
        color: var(--ink-ghost);
    }

    .talk-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    /* Media figure (wraps a video or slide-deck embed with caption + actions) */
    .talk-media {
        margin: 3rem 0;
    }

    .talk-media .media-container {
        margin: 0;
    }

    .media-caption {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        color: var(--ink-faint);
        margin: 0.75rem 0 0;
        line-height: 1.6;
        letter-spacing: 0.02em;
    }

    .media-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.75rem;
    }

    .media-action {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        color: var(--ink-light);
        background: transparent;
        border: 1px solid var(--ink-ghost);
        padding: 0.5rem 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        letter-spacing: 0.02em;
    }

    .media-action:hover,
    .media-action:focus-visible {
        border-color: var(--bloom);
        color: var(--bloom);
        outline: none;
    }

    .media-action[data-state="copied"] {
        border-color: var(--bloom);
        color: var(--bloom);
    }

    .media-action .icon {
        display: inline-block;
        margin-right: 0.35rem;
        font-size: 0.85rem;
        line-height: 1;
        transform: translateY(1px);
    }

    /* Slides lightbox — pop-out fullscreen for the deck */
    .slides-lightbox {
        position: fixed;
        inset: 0;
        z-index: 1000;
        background: rgba(0, 0, 0, 0.94);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 2.5rem 1.5rem 1.5rem;
    }

    .slides-lightbox.active {
        display: flex;
    }

    .slides-lightbox-frame {
        width: min(96vw, 100%);
        aspect-ratio: 16 / 9;
        max-height: 92vh;
        border: none;
        background: var(--paper-dark);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.55);
    }

    .slides-lightbox-close {
        position: absolute;
        top: 1.25rem;
        right: 1.5rem;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.45);
        color: rgba(255, 255, 255, 0.85);
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        padding: 0.5rem 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        letter-spacing: 0.05em;
    }

    .slides-lightbox-close:hover,
    .slides-lightbox-close:focus-visible {
        border-color: rgba(255, 255, 255, 0.9);
        color: white;
        outline: none;
    }

    /* Media embed (video, slides) */
    .media-container {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%; /* 16:9 aspect ratio */
        margin: 3rem 0;
        background: var(--paper-dark);
        border: 1px solid var(--ink-ghost);
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .media-container:hover {
        border-color: var(--bloom);
        box-shadow: 0 8px 24px var(--bloom-glow);
    }

    .media-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }

    /* Description/body content */
    .talk-body {
        line-height: 1.8;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--ink-ghost);
    }

    .talk-body p {
        margin-bottom: 1.5rem;
    }

    .talk-body a {
        color: var(--ink);
        text-decoration: underline;
        text-decoration-color: var(--ink-ghost);
        text-underline-offset: 2px;
    }

    .talk-body a:hover {
        color: var(--bloom);
    }

    .talk-title.accident {
        color: var(--accident);
    }

    .talk-body .accident {
        color: var(--accident);
    }

    /* External link button */
    .external-link {
        display: inline-block;
        margin-top: 2rem;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.75rem;
        color: var(--ink-light);
        text-decoration: none;
        padding: 0.75rem 1.25rem;
        border: 1px solid var(--ink-ghost);
        transition: all 0.2s ease;
    }

    .external-link:hover {
        border-color: var(--bloom);
        color: var(--bloom);
    }

    .external-link + .external-link {
        margin-left: 0.75rem;
    }

    .talk-footer {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid var(--ink-ghost);
        display: flex;
        justify-content: space-between;
    }

    .nav-link {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        color: var(--ink-faint);
    }

    .page-marker {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.65rem;
        color: var(--ink-ghost);
    }

    @media (max-width: 1100px) {
        .talk-container {
            grid-template-columns: 1fr;
            padding: 8rem 2rem 4rem;
        }

        .talk-content {
            grid-column: 1;
        }
    }

    @media (max-width: 768px) {
        .talk-container {
            padding: 6rem 1.5rem 3rem;
        }

        .talk-meta {
            flex-direction: column;
            gap: 0.5rem;
        }
    }
</style>

<div class="talk-container">

    <article class="talk-content" data-pagefind-body data-pagefind-filter="type:{{ type | default('talk') }}">

        <header class="talk-header">
            <div class="talk-num">{{ (type | default("talk")) | upper }} NO. {{ seriesNumber | default("01") }}</div>
            <h1 class="talk-title{% if accident %} accident{% endif %}">{{ title }}</h1>
            <div class="talk-meta">
                {% if speakers %}
                <span class="meta-item">
                    <span class="meta-label">with</span>
                    <span>{{ speakers | join(", ") }}</span>
                </span>
                {% endif %}
                {% if event %}
                <span class="meta-item">
                    <span class="meta-label">at</span>
                    <span>{{ event }}</span>
                </span>
                {% endif %}
                <span class="meta-item">
                    <span class="meta-label">date</span>
                    <span>{{ date | readableDate }}</span>
                </span>
            </div>
            {% if keywords %}
            <div class="talk-tags">
                {% for keyword in keywords %}
                <a href="/tag/{{ keyword | slugify }}/" class="tag">{{ keyword }}</a>
                {% endfor %}
            </div>
            {% endif %}
        </header>

        {% if youtube %}
        <figure class="talk-media">
            <div class="media-container">
                <iframe
                    src="https://www.youtube.com/embed/{{ youtube }}"
                    title="{{ title }}"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy">
                </iframe>
            </div>
            <figcaption class="media-caption">Recording — watch the full talk above.</figcaption>
        </figure>
        {% elif video %}
        <figure class="talk-media">
            <div class="media-container">
                <iframe
                    src="{{ video }}"
                    title="{{ title }}"
                    allowfullscreen
                    loading="lazy">
                </iframe>
            </div>
            <figcaption class="media-caption">Recording.</figcaption>
        </figure>
        {% endif %}

        {% if slides %}
        <figure class="talk-media" data-slides-figure>
            <div class="media-container">
                <iframe
                    src="{{ slides }}"
                    title="{{ title }} — slides"
                    allowfullscreen
                    loading="lazy"
                    data-slides-frame
                    data-slides-src="{{ slides }}">
                </iframe>
            </div>
            <figcaption class="media-caption">Slide deck{% if youtube or video %} — see the recording above for context{% endif %}. Pop out for fullscreen, or copy the link to share.</figcaption>
            <div class="media-actions">
                <button type="button" class="media-action" data-slides-fullscreen aria-label="Open slides fullscreen">
                    <span class="icon" aria-hidden="true">⤢</span>Fullscreen
                </button>
                <button type="button" class="media-action" data-slides-copy aria-label="Copy link to share">
                    <span class="icon" aria-hidden="true">⎘</span>Copy link
                </button>
            </div>
        </figure>
        {% endif %}

        {% if content | trim %}
        <div class="talk-body">
            {{ content | safe }}
        </div>
        {% endif %}

        {% if youtube %}
        <a href="https://www.youtube.com/watch?v={{ youtube }}" class="external-link">Watch on YouTube →</a>
        {% endif %}
        {% if slides %}
        <a href="{{ slides }}" class="external-link">View slides →</a>
        {% endif %}
        {% if link %}
        <a href="{{ link }}" class="external-link">Visit website →</a>
        {% endif %}

        <footer class="talk-footer">
            <a href="/talks/" class="nav-link">← all talks</a>
            <span class="page-marker">005</span>
        </footer>

    </article>

</div>

{% if slides %}
<div class="slides-lightbox" id="slides-lightbox" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Slide deck — full size">
    <button type="button" class="slides-lightbox-close" data-slides-lightbox-close aria-label="Close slides">close</button>
    <iframe class="slides-lightbox-frame" src="" title="{{ title }} — slides full size" allowfullscreen></iframe>
</div>

<script>
(function () {
    const figure = document.querySelector('[data-slides-figure]');
    if (!figure) return;

    const fullscreenBtn = figure.querySelector('[data-slides-fullscreen]');
    const copyBtn = figure.querySelector('[data-slides-copy]');
    const lightbox = document.getElementById('slides-lightbox');
    const lightboxFrame = lightbox && lightbox.querySelector('iframe');
    const lightboxClose = lightbox && lightbox.querySelector('[data-slides-lightbox-close]');
    const sourceFrame = figure.querySelector('[data-slides-frame]');
    const slidesUrl = sourceFrame && (sourceFrame.dataset.slidesSrc || sourceFrame.src);

    let triggerEl = null;

    function openLightbox() {
        if (!lightbox || !lightboxFrame) return;
        if (lightboxFrame.src !== slidesUrl) {
            lightboxFrame.src = slidesUrl;
        }
        triggerEl = document.activeElement;
        lightbox.classList.add('active');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        if (lightboxClose) lightboxClose.focus();
    }

    function closeLightbox() {
        if (!lightbox) return;
        lightbox.classList.remove('active');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        if (triggerEl && typeof triggerEl.focus === 'function') {
            triggerEl.focus();
            triggerEl = null;
        }
    }

    if (fullscreenBtn) fullscreenBtn.addEventListener('click', openLightbox);
    if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
    if (lightbox) {
        lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox) closeLightbox();
        });
    }
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && lightbox && lightbox.classList.contains('active')) {
            closeLightbox();
        }
    });

    function flashCopied() {
        if (!copyBtn) return;
        const original = copyBtn.innerHTML;
        copyBtn.innerHTML = '<span class="icon" aria-hidden="true">✓</span>Copied';
        copyBtn.dataset.state = 'copied';
        setTimeout(() => {
            copyBtn.innerHTML = original;
            delete copyBtn.dataset.state;
        }, 1800);
    }

    if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
            const url = window.location.href;
            if (navigator.clipboard && window.isSecureContext) {
                try {
                    await navigator.clipboard.writeText(url);
                    flashCopied();
                    return;
                } catch (_) { /* fall through to legacy path */ }
            }
            const ta = document.createElement('textarea');
            ta.value = url;
            ta.setAttribute('readonly', '');
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            try { document.execCommand('copy'); flashCopied(); } catch (_) {}
            document.body.removeChild(ta);
        });
    }
})();
</script>
{% endif %}
