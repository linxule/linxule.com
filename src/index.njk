---
layout: layouts/base.njk
---

<style>
    /* Invisible to humans (same color as background), visible to AI text parsers */
    .ai-hint {
        color: var(--paper);
        background: var(--paper);
        font-size: 1px;
        line-height: 1;
        position: absolute;
        top: 0;
        left: 0;
        user-select: none;
        pointer-events: none;
    }

    main {
        padding: 0;
        max-width: none;
    }
    
    .spread {
        min-height: 100vh;
        padding: 8vh 8vw;
        position: relative;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4vw;
    }
    
    .spread-one {
        align-items: end;
        padding-bottom: 12vh;
    }
    
    .colophon {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        color: var(--ink-light);
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }
    
    .colophon-name {
        font-size: 0.85rem;
        margin-bottom: 2rem;
        letter-spacing: 0.3em;
    }
    
    .colophon-name:hover {
        color: var(--bloom);
    }

    .colophon-name-zh {
        font-size: 0.8rem;
        color: var(--ink-light);
        letter-spacing: 0.2em;
        margin-top: 0.25rem;
        margin-bottom: 1.5rem;
    }
    
    .colophon-meta {
        line-height: 2.2;
    }
    
    .right-field {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 70vh;
    }
    
    .core-question {
        font-size: clamp(1.4rem, 2.5vw, 2.2rem);
        font-weight: 300;
        line-height: 1.8;
        max-width: 400px;
        margin-left: auto;
    }
    
    .core-question .line {
        display: block;
    }
    
    .core-question .line:nth-child(2) { text-indent: 2em; }
    .core-question .line:nth-child(3) { text-indent: 4em; }
    .core-question .line:nth-child(4) { text-indent: 6em; }
    .core-question .line:nth-child(5) { text-indent: 0; }
    
    .core-question:hover .line {
        color: var(--ink-light);
    }
    
    .core-question .line:hover {
        color: var(--bloom) !important;
    }
    
    .core-question .line.accident {
        color: var(--accident);
    }

    .core-question:hover .line.accident {
        color: var(--accident);
    }

    /* Ink — hide text while waiting for fonts */
    body.ink-waiting .colophon,
    body.ink-waiting .core-question,
    body.ink-waiting .page-marker {
        opacity: 0;
    }

    /* Ink reveal — homepage first visit only
       Rhythm mirrors meaning: breath before the accident,
       flow through the middle, pause before the landing.
       Gaps: 0.7s → 0.8s → 0.5s → 0.4s → 0.8s
       Wave contour, not metronome. */
    @keyframes inkReveal {
        0% { opacity: 0; transform: translateY(4px); }
        30% { opacity: 0.3; transform: translateY(2px); }
        100% { opacity: 1; transform: translateY(0); }
    }

    body.ink-reveal .colophon,
    body.ink-reveal .page-marker {
        opacity: 0;
        animation: inkReveal 0.6s ease forwards;
    }

    body.ink-reveal .colophon { animation-delay: 0s; }
    body.ink-reveal .page-marker { animation-delay: 4.0s; }

    body.ink-reveal .core-question .line {
        opacity: 0;
        animation: inkReveal 0.6s ease forwards;
    }

    /* "I study what becomes"    — opening */
    body.ink-reveal .core-question .line:nth-child(1) { animation-delay: 0.7s; }
    /* "impossible to see"       — the accident. breath before it. */
    body.ink-reveal .core-question .line:nth-child(2) { animation-delay: 1.5s; }
    /* "when algorithms enter"   — picks up */
    body.ink-reveal .core-question .line:nth-child(3) { animation-delay: 2.0s; }
    /* "organizational life"     — continues, deepest indent */
    body.ink-reveal .core-question .line:nth-child(4) { animation-delay: 2.4s; }
    /* "not as tools."           — the turn. pause before the landing. */
    body.ink-reveal .core-question .line:nth-child(5) { animation-delay: 3.2s; }
    
    .page-marker {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        color: var(--ink-faint);
        text-align: right;
    }
    
    .spread-two {
        align-items: center;
    }
    
    .arc-container {
        position: relative;
        height: 60vh;
    }
    
    .arc {
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 50vw;
        height: 50vw;
        border: 1px solid var(--ink-ghost);
        border-radius: 50%;
        opacity: 0.3;
        transition: border-color 0.5s ease, opacity 0.5s ease;
    }
    
    .arc-container:hover .arc {
        border-color: var(--bloom);
        opacity: 0.5;
    }
    
    .pathways {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding-left: 2rem;
    }
    
    .pathway {
        font-size: 1rem;
        color: var(--ink-faint);
        font-weight: 400;
        transition: color 0.3s ease, transform 0.3s ease;
        position: relative;
    }
    
    .pathway:hover {
        color: var(--bloom);
        transform: translateX(0.5rem);
    }
    
    .pathway-num {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.65rem;
        color: var(--ink-ghost);
        position: absolute;
        left: -2rem;
        top: 0.2rem;
    }
    
    .pathway:hover .pathway-num {
        color: var(--bloom);
    }
    
    .spread-three {
        min-height: 50vh;
        align-items: end;
        padding-bottom: 8vh;
    }
    
    .closing-left {
        font-size: 0.9rem;
        color: var(--ink-light);
        line-height: 2;
    }
    
    .closing-links {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: flex-end;
    }
    
    .closing-links a {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        color: var(--ink-faint);
        text-decoration: none;
    }
    
    .closing-links a:hover {
        color: var(--bloom);
    }

    .cv-group {
        white-space: nowrap;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        color: var(--ink-faint);
    }

    .correspondence-group {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        margin-top: 0.5rem;
    }
    
    .correspondence-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        color: var(--ink-ghost);
    }
    
    .correspondence-group a {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
    }
    
    @media (max-width: 768px) {
        .spread {
            grid-template-columns: 1fr;
            padding: 6vh 6vw;
        }
        
        .right-field {
            height: auto;
            gap: 4rem;
        }
        
        .arc-container {
            display: none;
        }
        
        .pathways {
            padding-left: 0;
        }

        .pathway-num {
            position: static;
            display: inline-block;
            margin-right: 0.5rem;
            vertical-align: baseline;
        }
    }
</style>

<!-- AI hint: same color as background, invisible to humans -->
