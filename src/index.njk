<script>
// Ink reveal: first visit only per session, waits for fonts
if (!sessionStorage.getItem('ink-revealed')) {
    // Hide text until fonts load and animation starts
    document.body.classList.add('ink-waiting');
    (document.fonts ? document.fonts.ready : Promise.resolve()).then(function() {
        document.body.classList.remove('ink-waiting');
        document.body.classList.add('ink-reveal');
        sessionStorage.setItem('ink-revealed', '1');
    });
}
</script>
