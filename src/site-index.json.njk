---
permalink: /site-index.json
eleventyExcludeFromCollections: true
---
{
  "version": "{{ "" | isoDate }}",
  "site": {
    "title": "{{ site.title }}",
    "url": "{{ site.url }}",
    "author": "{{ site.author }}",
    "description": "{{ site.description }}"
  },
  "pages": [
{%- for post in collections.writing %}
    {
      "url": "{{ post.url | replace(r/\/$/, "") }}",
      "url_md": "/writing/{{ post.fileSlug }}.md",
      "title": {{ post.data.title | dump | safe }},
      "section": "writing",
      "date": "{{ post.date.toISOString().split('T')[0] }}",
      "authors": [{% for author in post.data.authors %}{{ author | dump | safe }}{% if not loop.last %}, {% endif %}{% endfor %}],
      "keywords": [{% for kw in post.data.keywords %}{{ kw | dump | safe }}{% if not loop.last %}, {% endif %}{% endfor %}],
      "summary": {{ (post.data.description or post.data.subtitle or '') | truncate(160) | replace('\n', ' ') | dump | safe }}
    }{% if not loop.last or collections.portraits.length or collections.artifacts.length or collections.talks.length %},{% endif %}
{%- endfor %}
{%- for portrait in collections.portraits %}
    {
      "url": "{{ portrait.url | replace(r/\/$/, "") }}",
      "url_md": "{{ portrait.url | replace(r/\/$/, "") }}.md",
      "title": {{ portrait.data.title | dump | safe }},
      "section": "portraits",
      "date": "{{ portrait.date.toISOString().split('T')[0] }}",
      "prompter": {{ (portrait.data.prompter or '') | dump | safe }},
      "generator": {{ (portrait.data.generator or '') | dump | safe }},
      "summary": {% if portrait.data.prompt and portrait.data.prompt[0] %}{{ (portrait.data.prompt[0].text or portrait.data.prompt[0]) | truncate(160) | replace('\n', ' ') | dump | safe }}{% else %}""{% endif %}
    }{% if not loop.last or collections.artifacts.length or collections.talks.length %},{% endif %}
{%- endfor %}
{%- for artifact in collections.artifacts %}
    {
      "url": "{{ artifact.url | replace(r/\/$/, "") }}",
      "url_md": "{{ artifact.url | replace(r/\/$/, "") }}.md",
      "title": {{ artifact.data.title | dump | safe }},
      "section": "artifacts",
      "date": "{{ artifact.date.toISOString().split('T')[0] }}",
      "creator": {{ (artifact.data.creator or '') | dump | safe }},
      "medium": {{ (artifact.data.medium or '') | dump | safe }},
      "keywords": [{% for kw in artifact.data.keywords %}{{ kw | dump | safe }}{% if not loop.last %}, {% endif %}{% endfor %}],
      "summary": {% if artifact.data.contextExcerpt and artifact.data.contextExcerpt[0] %}{{ (artifact.data.contextExcerpt[0].text or artifact.data.contextExcerpt[0]) | truncate(160) | replace('\n', ' ') | dump | safe }}{% else %}""{% endif %}
    }{% if not loop.last or collections.talks.length %},{% endif %}
{%- endfor %}
{%- for talk in collections.talks %}
    {
      "url": "{{ talk.url | replace(r/\/$/, "") }}",
      "url_md": "/talks/{{ talk.fileSlug }}.md",
      "title": {{ talk.data.title | dump | safe }},
      "section": "talks",
      "date": "{{ talk.date.toISOString().split('T')[0] }}",
      "event": {{ (talk.data.event or '') | dump | safe }},
      "speakers": [{% for speaker in talk.data.speakers %}{{ speaker | dump | safe }}{% if not loop.last %}, {% endif %}{% endfor %}],
      "keywords": [{% for kw in talk.data.keywords %}{{ kw | dump | safe }}{% if not loop.last %}, {% endif %}{% endfor %}],
      "youtube": {{ (talk.data.youtube or '') | dump | safe }}
    }{% if not loop.last %},{% endif %}
{%- endfor %}
  ],
  "concepts": [
{%- for concept in collections.concepts %}
    {
      "term": {{ concept.term | dump | safe }},
      "definition": {{ concept.definition | dump | safe }},
      "url": "{{ concept.url | replace(r/\/$/, "") }}#{{ concept.anchor }}",
      "canonicalEssay": {{ concept.title | dump | safe }},
      "authors": [{% for author in concept.authors %}{{ author | dump | safe }}{% if not loop.last %}, {% endif %}{% endfor %}],
      "date": "{{ concept.date.toISOString().split('T')[0] }}"
    }{% if not loop.last %},{% endif %}
{%- endfor %}
  ],
  "publications": [
    {
      "title": "Interpretive Orchestration: An Essay Exploring the Epistemic Intersection of Human Intuition and Machine Intelligence",
      "authors": ["Xule Lin", "Kevin G. Corley"],
      "year": 2026,
      "venue": "Strategic Organization",
      "type": "journal-article",
      "status": "advance online publication",
      "doi": "10.1177/14761270261448645",
      "url": "https://doi.org/10.1177/14761270261448645",
      "ssrn": "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=6629679",
      "code": "https://github.com/linxule/interpretive-orchestration-paper",
      "license": "CC BY 4.0",
      "coins": "Interpretive Orchestration",
      "onSite": "https://linxule.com/writing/research-memex"
    },
    {
      "title": "Cognitio Emergens: Agency, Dimensions, and Dynamics in Human–AI Knowledge Co-Creation",
      "authors": ["Xule Lin"],
      "year": 2025,
      "venue": "arXiv",
      "type": "preprint",
      "arxiv": "2505.03105",
      "url": "https://arxiv.org/abs/2505.03105"
    }
  ]
}
