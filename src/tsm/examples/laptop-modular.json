        { "from": "dr1", "to": "m-spec", "mark": "x", "rendering": { "arrow": true, "emphasis": "primary", "lens": "coordinator-dispatch" } },
        { "from": "dr1", "to": "d-spec", "mark": "x", "rendering": { "arrow": true, "emphasis": "primary", "lens": "coordinator-dispatch" } },
        { "from": "dr1", "to": "c-spec", "mark": "x", "rendering": { "arrow": true, "emphasis": "primary", "lens": "coordinator-dispatch" } },

        { "from": "dr2", "to": "s-design", "mark": "x", "rendering": { "emphasis": "secondary", "lens": "coordinator-dispatch" } },
        { "from": "dr2", "to": "m-design", "mark": "x", "rendering": { "emphasis": "secondary", "lens": "coordinator-dispatch" } },
        { "from": "dr2", "to": "d-design", "mark": "x", "rendering": { "emphasis": "secondary", "lens": "coordinator-dispatch" } },
