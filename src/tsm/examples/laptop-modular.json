{
  "specVersion": "0.4.0",
  "kind": "tsm-scene",
  "id": "laptop-modular",
  "title": "Designing a modular laptop computer",
  "source": "Adapted from Baldwin (2026), <em>A theory of technology and organizations</em>, Figure 3",
  "lenses": ["coordinator-dispatch", "cross-region-edge", "modularity-boundary"],

  "narrative": {
    "mode": "walkthrough",
    "steps": [
      {
        "caption": "<strong>Step 1.</strong> All the tasks line up along the diagonal — design rules first, then the four component modules, then system integration.",
        "reveal": { "include": ["diagonal"] }
      },
      {
        "caption": "<strong>Step 2.</strong> Design rules dispatch downward to every module. Specifying interfaces in advance — once — replaces the criss-cross coordination that integral systems require. All three rows of dispatch arrows fire from the design-rule region.",
        "reveal": { "include": ["diagonal", "transfer:directed:forward"] },
        "setEmphasis": {
          "primary": { "byLens": ["coordinator-dispatch"] }
        }
      },
      {
        "caption": "<strong>Step 3.</strong> Inside each module, the local recipe runs: spec, design, test, with feedback. Each module is its own self-contained TSM. The dispatch arrows fade back to context.",
        "reveal": { "include": ["diagonal", "transfer:directed:forward", "transfer:directed:backward"] }
      },
      {
        "caption": "<strong>Step 4.</strong> The finished modules feed system integration. Notice what isn't here: <em>no transfers between modules</em>. The design rules absorbed all the coordination work upfront, so the modules don't need to talk to each other. The module boundaries become loud.",
        "reveal": {
          "include": [
            "diagonal",
            "transfer:directed:forward",
            "transfer:directed:backward",
            "overlay:module-border"
          ]
        },
        "setEmphasis": {
          "primary": { "byLens": ["modularity-boundary"] }
        }
      }
    ]
  },

  "matrices": [
    {
      "id": "laptop",
      "architectureType": "modular",

      "regions": [
        { "id": "dr",          "layoutKind": "left-band",      "semanticKind": "design-rules", "label": "Design Rules" },
        { "id": "screen",      "layoutKind": "diagonal-block", "semanticKind": "module",       "label": "Screen" },
        { "id": "mobo",        "layoutKind": "diagonal-block", "semanticKind": "module",       "label": "Motherboard" },
        { "id": "drive",       "layoutKind": "diagonal-block", "semanticKind": "module",       "label": "Drive" },
        { "id": "case",        "layoutKind": "diagonal-block", "semanticKind": "module",       "label": "Casing" },
        { "id": "integration", "layoutKind": "bottom-band",    "semanticKind": "integration",  "label": "Integration" }
      ],

      "tasks": [
        { "id": "dr1", "label": "DR1", "region": "dr" },
        { "id": "dr2", "label": "DR2", "region": "dr" },
        { "id": "dr3", "label": "DR3", "region": "dr" },

        { "id": "s-spec",   "label": "Spec",   "region": "screen" },
        { "id": "s-design", "label": "Design", "region": "screen" },
        { "id": "s-test",   "label": "Test",   "region": "screen" },

        { "id": "m-spec",   "label": "Spec",   "region": "mobo" },
        { "id": "m-design", "label": "Design", "region": "mobo" },
        { "id": "m-layout", "label": "Layout", "region": "mobo" },
        { "id": "m-test",   "label": "Test",   "region": "mobo" },

        { "id": "d-spec",   "label": "Spec",   "region": "drive" },
