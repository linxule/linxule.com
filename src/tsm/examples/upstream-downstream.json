        { "from": "U4", "to": "U5", "mark": "x" },
        { "from": "U4", "to": "U6", "mark": "x" },
        { "from": "U5", "to": "U1", "mark": "x", "rendering": { "lens": "cyclic-flow" } },
        { "from": "U5", "to": "U2", "mark": "x", "rendering": { "lens": "cyclic-flow" } },
        { "from": "U5", "to": "U3", "mark": "x", "rendering": { "lens": "cyclic-flow" } },
        { "from": "U5", "to": "U4", "mark": "x", "rendering": { "arrow": true, "emphasis": "primary", "lens": "cyclic-flow" } },
        { "from": "U5", "to": "U6", "mark": "x" },
        { "from": "U6", "to": "U1", "mark": "x", "rendering": { "arrow": true, "label": "long cycle", "emphasis": "primary", "lens": "cyclic-flow" } },
        { "from": "U6", "to": "U2", "mark": "x", "rendering": { "lens": "cyclic-flow" } },
        { "from": "U6", "to": "U3", "mark": "x", "rendering": { "lens": "cyclic-flow" } },
        { "from": "U6", "to": "U4", "mark": "x", "rendering": { "lens": "cyclic-flow" } },
        { "from": "U6", "to": "U5", "mark": "x", "rendering": { "arrow": true, "emphasis": "primary", "lens": "cyclic-flow" } }
      ],

      "overlays": [
        { "kind": "firm-boundary", "rendering": { "emphasis": "primary", "lens": "modularity-boundary" } }
      ]
    },
    {
      "id": "downstream",
      "architectureType": "flow",

      "narrative": {
        "mode": "walkthrough",
        "steps": [
          {
            "caption": "<strong>Downstream — Step 1.</strong> Six tasks (D1–D6) on the diagonal, wrapped in a firm boundary. Same firm-as-circle convention as Upstream; different architecture inside.",
            "reveal": { "include": ["diagonal", "overlay:firm-boundary"] }
          },
          {
            "caption": "<strong>Downstream — Step 2.</strong> Forward transfers run straight down the line. Each task hands its output to the next station — D1→D2, D2→D3, and so on. No criss-crossing, no rework: that is what makes this a synchronized flow rather than a job shop.",
            "reveal": {
              "include": [
                "diagonal",
                "transfer:directed:forward",
                "overlay:firm-boundary"
              ]
            }
          },
          {
            "caption": "<strong>Downstream — Step 3.</strong> Backward marks appear above the diagonal — but these are <code>s</code>, not <code>x</code>. Each station signals upstream when it is ready for the next unit: D2 signals D1, D3 signals D2, and so on. Kanban pull, not rework.",
            "reveal": {
              "include": [
                "diagonal",
                "transfer:directed:forward",
                "transfer:directed:backward",
                "overlay:firm-boundary"
              ]
            }
          },
          {
            "caption": "<strong>Downstream — Step 4.</strong> The contract with Upstream feeds raw goods to D1 and sends payment in return. Inside the firm boundary, transfers are free; the contract is the single thin crossing point where transactions are recorded.",
            "reveal": {
              "include": [
                "diagonal",
                "transfer:directed:forward",
                "transfer:directed:backward",
                "overlay:firm-boundary"
              ]
            }
          }
        ]
      },

      "regions": [
        { "id": "downstream-firm", "layoutKind": "diagonal-block", "semanticKind": "task", "label": "Downstream (flow)" }
      ],

      "tasks": [
        { "id": "D1", "label": "Downstream task 1", "shortLabel": "D1", "region": "downstream-firm" },
