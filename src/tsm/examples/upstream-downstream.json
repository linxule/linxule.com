        { "id": "U2", "label": "Upstream task 2", "shortLabel": "U2", "region": "upstream-firm" },
        { "id": "U3", "label": "Upstream task 3", "shortLabel": "U3", "region": "upstream-firm" },
        { "id": "U4", "label": "Upstream task 4", "shortLabel": "U4", "region": "upstream-firm" },
        { "id": "U5", "label": "Upstream task 5", "shortLabel": "U5", "region": "upstream-firm" },
        { "id": "U6", "label": "Upstream task 6", "shortLabel": "U6", "region": "upstream-firm" }
      ],

