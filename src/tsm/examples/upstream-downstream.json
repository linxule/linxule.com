        { "from": "D2", "to": "D1", "mark": "s", "rendering": { "arrow": true, "label": "pull signal", "emphasis": "primary" } },
        { "from": "D3", "to": "D2", "mark": "s", "rendering": { "arrow": true, "emphasis": "primary" } },
        { "from": "D4", "to": "D3", "mark": "s", "rendering": { "arrow": true, "emphasis": "primary" } },
        { "from": "D5", "to": "D4", "mark": "s", "rendering": { "arrow": true, "emphasis": "primary" } },
        { "from": "D6", "to": "D5", "mark": "s", "rendering": { "arrow": true, "emphasis": "primary" } }
      ],

      "overlays": [
