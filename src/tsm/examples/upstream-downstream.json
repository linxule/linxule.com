        { "id": "D6", "label": "Downstream task 6", "shortLabel": "D6", "region": "downstream-firm" }
      ],

      "transfers": [
        { "from": "D1", "to": "D2", "mark": "x", "rendering": { "arrow": true, "label": "flow", "emphasis": "primary", "lens": "forward-handoff" } },
        { "from": "D2", "to": "D3", "mark": "x", "rendering": { "arrow": true, "emphasis": "primary", "lens": "forward-handoff" } },
